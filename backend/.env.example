# Copy this file to ".env" in the backend/ folder and fill in real values.
# ".env" itself must NEVER be committed to git (see .gitignore).

SERVER_PORT=8080

# MySQL connection
DB_URL=jdbc:mysql://localhost:3306/preppilot?useSSL=false&serverTimezone=UTC&createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=your-mysql-password

DDL_AUTO=update
SHOW_SQL=false

# Generate a strong random string for production, e.g.: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION_MS=86400000

GRANITE_API_URL=https://your-granite-endpoint
GRANITE_API_KEY=replace-with-your-ibm-granite-api-key

CORS_ALLOWED_ORIGIN=http://localhost:5173
